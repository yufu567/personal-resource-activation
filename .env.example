APP_URL=http://localhost:3000
APP_VERSION=local
AI_PROVIDER=mock

DATABASE_URL=postgres://resource_activation:resource_activation@postgres:5432/resource_activation
REDIS_URL=redis://redis:6379

OBJECT_STORAGE_ENDPOINT=https://example-r2-or-s3-endpoint
OBJECT_STORAGE_BUCKET=resource-activation
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key

AUTH_SECRET=replace-with-a-long-random-value
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# GitHub OAuth (create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_TRUST_HOST=true

# Set to "1" after filling AUTH_GITHUB_ID/SECRET above to show the GitHub login button
NEXT_PUBLIC_HAS_GITHUB=0

# AI Research — SearXNG self-hosted search engine
# Started automatically by Docker Compose
SEARXNG_ENDPOINT=http://searxng:8080

# Sentry error monitoring (optional)
# Get DSN at https://sentry.io → Create Project → Next.js
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
