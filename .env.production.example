# ── Production Environment Variables ──
# Copy: cp .env.production.example .env.production
# NEVER commit .env or .env.production to git.

APP_URL=https://your-domain.com
APP_VERSION=production
NODE_ENV=production

# AI Provider: mock | openai | anthropic
AI_PROVIDER=mock

# Data store: memory | postgres
STORE=postgres

# PostgreSQL (required when STORE=postgres)
DATABASE_URL=postgres://user:password@postgres:5432/resource_activation

# Redis (for queues & background work)
REDIS_URL=redis://redis:6379

# Object Storage (S3-compatible, for file uploads)
OBJECT_STORAGE_ENDPOINT=https://your-r2-endpoint
OBJECT_STORAGE_BUCKET=resource-activation
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=your-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=your-secret-access-key

# Auth — MUST be long random strings in production
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-long-random-string-32-chars-min
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Optional: Sentry DSN for error monitoring
# SENTRY_DSN=https://...
